# SDK Web Firebase (client — préfixe NEXT_PUBLIC obligatoire)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Admin SDK Firebase (serveur uniquement — ne jamais exposer côté client)
# Disponible dans Firebase Console > Paramètres du projet > Comptes de service > Générer une clé privée
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Secret de session JWT (chaîne aléatoire longue, ex: openssl rand -hex 32)
SESSION_SECRET=

# Hash bcrypt factice pour la protection contre les timing attacks sur le login
# Générer avec : node -e "require('bcryptjs').hash('dummy',12).then(console.log)"
DUMMY_BCRYPT_HASH=
